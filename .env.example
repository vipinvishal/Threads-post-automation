# ── Gemini AI (post generation) ──────────────────────────────────────────────
# Get keys: https://aistudio.google.com/apikey
# GEMINI_API_KEY_2 is optional — auto-used when primary hits daily quota
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_2=your_second_gemini_api_key_here

# Optional: override model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# ── Euron fallback (used when ALL Gemini keys are exhausted) ──────────────────
# Get key: https://euron.one
EURON_API_KEY=your_euron_api_key_here

# ── Exa (real-time neural web research) ──────────────────────────────────────
# Get key: https://exa.ai → Dashboard → API Keys
EXA_API_KEY=your_exa_api_key_here

# ── Buffer (schedules posts to X) ────────────────────────────────────────────
# Get API key: https://buffer.com → Settings → API
# Get Channel ID: run  python scripts/get_buffer_channel.py
BUFFER_API_KEY=your_buffer_api_key_here
BUFFER_CHANNEL_ID=your_buffer_x_channel_id_here

# ── X handle shown on tweet cards ────────────────────────────────────────────
X_HANDLE=@yourhandle
